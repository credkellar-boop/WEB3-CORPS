# WEB3-Corps Runtime Environment Settings
RUST_LOG=info
MATRIX_ENVIRONMENT=production

# Blockchain Infrastructure Core Nodes
L3_CHAIN_ID=7733
PARENT_L2_RPC_URL=https://arbitrum-mainnet.infura.io/v3/YOUR_API_KEY
